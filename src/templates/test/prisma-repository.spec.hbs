import { Test, TestingModule } from "@nestjs/testing";
import { {{entityNamePascal}} as Prisma{{entityNamePascal}} } from "@prisma/client";
import { PrismaService } from "@prisma/prisma.service";
import { {{entityNamePascal}}Repository } from "./{{entityNameKebab}}.repository";
import { {{entityNamePascal}}Mapper } from "../mappers/{{entityNameKebab}}.mapper";
import { {{entityNamePascal}}Entity } from "@modules/{{moduleNameKebab}}/application/domain/entities/{{entityNameKebab}}.entity";

describe("{{entityNamePascal}}Repository", () => {
  let repository: {{entityNamePascal}}Repository;
  let mapper: jest.Mocked<{{entityNamePascal}}Mapper>;

  const prismaDelegate = {
    create: jest.fn(),
    findFirst: jest.fn(),
    findMany: jest.fn(),
    count: jest.fn(),
    update: jest.fn(),
    delete: jest.fn(),
  };

  const mockPrismaEntity = {
    id: "test-uuid",
{{#each fields}}
    {{this.snakeCase}}: undefined as never,
{{/each}}
    is_active: true,
    created_at: new Date(),
    updated_at: new Date(),
{{#if softDelete}}
    deleted_at: null,
{{/if}}
  } as Prisma{{entityNamePascal}};

  const mockDomainEntity = new {{entityNamePascal}}Entity({
    id: "test-uuid",
{{#each fields}}
    {{this.camelCase}}: undefined as never,
{{/each}}
    isActive: true,
    createdAt: new Date(),
    updatedAt: new Date(),
  });

  beforeEach(async () => {
    const module: TestingModule = await Test.createTestingModule({
      providers: [
        {{entityNamePascal}}Repository,
        {
          provide: PrismaService,
          useValue: {
            {{entityNameCamel}}: prismaDelegate,
          },
        },
        {
          provide: {{entityNamePascal}}Mapper,
          useValue: {
            toPrismaCreate: jest.fn(),
            toPrismaUpdate: jest.fn(),
            toDomainEntity: jest.fn(),
            toResponseDto: jest.fn(),
          },
        },
      ],
