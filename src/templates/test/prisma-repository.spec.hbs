  });

  describe("findById", () => {
    it("should return a domain entity when found", async () => {
      prismaDelegate.findFirst.mockResolvedValue(mockPrismaEntity);
      mapper.toDomainEntity.mockReturnValue(mockDomainEntity);

      const result = await repository.findById("test-uuid");

      expect(prismaDelegate.findFirst).toHaveBeenCalledWith({
{{#if softDelete}}
        where: { id: "test-uuid", deleted_at: null },
{{else}}
        where: { id: "test-uuid" },
{{/if}}
      });
      expect(result).toEqual(mockDomainEntity);
    });

    it("should return null when the entity is not found", async () => {
      prismaDelegate.findFirst.mockResolvedValue(null);

      await expect(repository.findById("missing-uuid")).resolves.toBeNull();
    });
  });

  describe("findAllPaginated", () => {
    it("should return paginated entities with a total count", async () => {
      prismaDelegate.findMany.mockResolvedValue([mockPrismaEntity]);
      prismaDelegate.count.mockResolvedValue(1);
      mapper.toDomainEntity.mockReturnValue(mockDomainEntity);

      const result = await repository.findAllPaginated({
        skip: 0,
        take: 10,
        orderBy: "created_at",
        orderDirection: "DESC",
      });

      expect(result[0]).toHaveLength(1);
      expect(result[1]).toBe(1);
    });
  });

  describe("update", () => {
    it("should update and return a domain entity", async () => {
      mapper.toPrismaUpdate.mockReturnValue({});
      prismaDelegate.update.mockResolvedValue(mockPrismaEntity);
      mapper.toDomainEntity.mockReturnValue(mockDomainEntity);

      const result = await repository.update("test-uuid", mockDomainEntity);

      expect(prismaDelegate.update).toHaveBeenCalledWith({
        where: { id: "test-uuid" },
        data: {},
      });
      expect(result).toEqual(mockDomainEntity);
    });
  });

  describe("delete", () => {
{{#if softDelete}}
    it("should soft delete the entity", async () => {
      prismaDelegate.update.mockResolvedValue(mockPrismaEntity);

      await repository.delete("test-uuid");

      expect(prismaDelegate.update).toHaveBeenCalledWith({
        where: { id: "test-uuid" },
        data: expect.objectContaining({ deleted_at: expect.any(Date) }),
      });
    });
{{else}}
    it("should delete the entity", async () => {
      prismaDelegate.delete.mockResolvedValue(mockPrismaEntity);

      await repository.delete("test-uuid");

      expect(prismaDelegate.delete).toHaveBeenCalledWith({
        where: { id: "test-uuid" },
      });
    });
{{/if}}
  });

{{#if hardDelete}}
  describe("hardDelete", () => {
    it("should permanently delete the entity after explicit opt-in", async () => {
      prismaDelegate.delete.mockResolvedValue(mockPrismaEntity);

      await repository.hardDelete("test-uuid");

      expect(prismaDelegate.delete).toHaveBeenCalledWith({
        where: { id: "test-uuid" },
      });
    });
  });

{{/if}}
  describe("exists", () => {
    it("should return whether the entity exists", async () => {
      prismaDelegate.count.mockResolvedValue(1);

      await expect(repository.exists("test-uuid")).resolves.toBe(true);
    });
  });
